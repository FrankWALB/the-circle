generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  externalId String   @unique
  name       String
  email      String?
  role       Role     @default(USER)
  persons    Person[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

model Person {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  nickname   String?
  occupation String?
  company    String?
  birthday   DateTime?
  location   String?
  phone      String?
  email      String?
  metAt      String?
  notes      Note[]
  facts      Fact[]
  events     Event[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@map("persons")
}

model Note {
  id        String   @id @default(uuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId])
  @@map("notes")
}

model Fact {
  id        String   @id @default(uuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  key       String
  value     String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId])
  @@map("facts")
}

model Event {
  id        String   @id @default(uuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  recurring Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId])
  @@map("events")
}

enum Role {
  USER
  ADMIN
}
